<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen_7x"
    android:background="@drawable/tab_bg_selected"
    android:gravity="center"
    android:orientation="vertical" >

    <ImageView
        android:id="@+id/imgIcon"
        android:layout_width="@dimen/dimen_3x"
        android:layout_height="@dimen/dimen_3x"
        android:scaleType="center" />
    <TextView
        android:layout_marginTop="@dimen/dimen_05x"
        android:id="@+id/text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_upper_case"
        android:textSize="@dimen/text_size_small_3x"
        android:textColor="@color/cl_white"/>

</LinearLayout>