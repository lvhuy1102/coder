<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@android:color/white">

    <fragment
        android:id="@+id/fragmentRegister"
        android:name="com.hcpt.marketplace.activity.tabs.user.RegisterFragment"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <fragment
        android:id="@+id/fragmentMyAcc"
        android:name="com.hcpt.marketplace.activity.tabs.user.AccountFragment"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <fragment
        android:id="@+id/fragmentHistory"
        android:name="com.hcpt.marketplace.activity.tabs.user.HistoryFragment"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <fragment
        android:id="@+id/fragmentFeedBack"
        android:name="com.hcpt.marketplace.activity.tabs.user.FeedBackFragment"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <fragment
        android:id="@+id/fragmentLogin"
        android:name="com.hcpt.marketplace.activity.tabs.user.LoginFragment"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />


</RelativeLayout>